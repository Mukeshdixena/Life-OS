generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

enum LifeArea {
  LEARNING
  HEALTH
  WORK
  CREATIVITY
  SOCIAL
  MINDFULNESS
  FINANCE
}

enum TaskImportance {
  LOW
  MEDIUM
  HIGH
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String?
  createdAt    DateTime      @default(now())
  entries      InputEntry[]
  tasks        Task[]
  habits       Habit[]
  projects     Project[]
  progress     ProgressLog[]
  diary        DiaryEntry[]
  daily        DailySummary[]
  guru         GuruMessage[]
  timeBlocks   TimeBlock[]
  routines     Routine[]
}

model InputEntry {
  id             String   @id @default(cuid())
  userId         String
  rawText        String
  mood           Int?
  energy         Int?
  structuredJson Json
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id          String         @id @default(cuid())
  userId      String
  title       String
  dueDate     DateTime?
  importance  TaskImportance @default(MEDIUM)
  completedAt DateTime?
  source      String?
  createdAt   DateTime       @default(now())
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Habit {
  id          String       @id @default(cuid())
  userId      String
  name        String
  lifeArea    LifeArea     @default(HEALTH)
  createdAt   DateTime     @default(now())
  completions HabitLog[]
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  date      DateTime
  completed Boolean
  note      String?
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

model Project {
  id        String       @id @default(cuid())
  userId    String
  name      String
  lifeArea  LifeArea     @default(WORK)
  progress  Int          @default(0)
  createdAt DateTime     @default(now())
  sessions  WorkSession[]
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model WorkSession {
  id        String   @id @default(cuid())
  projectId String
  minutes   Int
  note      String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model TimeBlock {
  id           String    @id @default(cuid())
  userId       String
  title        String
  lifeArea     LifeArea  @default(WORK)
  date         DateTime
  startMinutes Int       // minutes from midnight (0-1439)
  durationMins Int       @default(60)
  taskId       String?
  completedAt  DateTime?
  note         String?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProgressLog {
  id        String   @id @default(cuid())
  userId    String
  lifeArea  LifeArea
  points    Int
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailySummary {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime
  productivity Int      @default(0)
  summary      String
  areas        LifeArea[]
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model DiaryEntry {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  mood      Int?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GuruMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Routine {
  id        String         @id @default(cuid())
  userId    String
  name      String         // e.g., "Weekday", "Weekend"
  blocks    RoutineBlock[]
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model RoutineBlock {
  id           String    @id @default(cuid())
  routineId    String
  title        String
  lifeArea     LifeArea  @default(WORK)
  startMinutes Int       // minutes from midnight (0-1439)
  durationMins Int       @default(60)
  routine      Routine   @relation(fields: [routineId], references: [id], onDelete: Cascade)
}
